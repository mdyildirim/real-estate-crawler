{
  "name": "real-estate-crawler",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype crawler for Turkiye city/district real-estate listings",
  "scripts": {
    "crawl": "node src/crawl.js",
    "crawl:quick": "node src/crawl.js --sources=emlakjet,atasehirsatilik,turyap_251316,sahibinden,hepsiemlak",
    "push:cf": "node src/push-to-cloudflare.js",
    "db:remote:migrate": "wrangler d1 migrations apply real-estate-crawler --remote",
    "db:local:migrate": "wrangler d1 migrations apply real-estate-crawler --local",
    "pages:dev": "wrangler pages dev public"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "wrangler": "^4.70.0"
  }
}
